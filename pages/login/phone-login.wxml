<!-- 手机号登录页面 -->
<view class="phone-login-container">
  <!-- 背景装饰 -->
  <view class="phone-bg-decoration">
    <!-- 渐变光晕 -->
    <view class="phone-bg-glow phone-glow-1"></view>
    <view class="phone-bg-glow phone-glow-2"></view>
    <view class="phone-bg-glow phone-glow-3"></view>
    
    <!-- 装饰圆点 -->
    <view class="phone-decor-dot phone-dot-1"></view>
    <view class="phone-decor-dot phone-dot-2"></view>
    <view class="phone-decor-dot phone-dot-3"></view>
    
    <!-- 波浪线条 -->
    <view class="phone-wave-line phone-wave-1"></view>
    <view class="phone-wave-line phone-wave-2"></view>
  </view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
      <text class="back-text">返回</text>
    </view>
    <text class="page-title">手机号登录</text>
    <view class="placeholder"></view>
  </view>

  <!-- 主要内容 -->
  <view class="login-content">
    <!-- 标题区域 -->
    <view class="header-section">
      <text class="main-title">欢迎登录</text>
      <text class="sub-title">使用手机号验证码登录</text>
    </view>

    <!-- 登录表单 -->
    <view class="login-form">
      <!-- 手机号输入 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">📱</text>
          <text class="label-text">手机号</text>
        </view>
        <view class="input-wrapper">
          <input 
            class="phone-input" 
            type="number" 
            maxlength="11" 
            placeholder="请输入手机号" 
            placeholder-class="input-placeholder"
            value="{{phoneNumber}}"
            bindinput="onPhoneInput"
          />
        </view>
      </view>

      <!-- 验证码输入 -->
      <view class="input-group">
        <view class="input-label">
          <text class="label-icon">🔐</text>
          <text class="label-text">验证码</text>
        </view>
        <view class="input-wrapper">
          <input 
            class="code-input" 
            type="number" 
            maxlength="6" 
            placeholder="请输入验证码" 
            placeholder-class="input-placeholder"
            value="{{verifyCode}}"
            bindinput="onCodeInput"
          />
          <button 
            class="send-code-btn" 
            bindtap="sendVerifyCode" 
            disabled="{{!canSendCode || countdown > 0}}"
            loading="{{sendingCode}}"
          >
            {{countdown > 0 ? countdown + 's' : '获取验证码'}}
          </button>
        </view>
      </view>

      <!-- 登录按钮 -->
      <button 
        class="login-submit-btn" 
        bindtap="handlePhoneLogin" 
        hover-class="button-hover"
        hover-stay-time="150"
        disabled="{{!phoneNumber || !verifyCode}}"
      >
        登录
      </button>
    </view>

    <!-- 底部提示 -->
    <view class="login-footer">
      <text class="footer-text">未注册的手机号验证后将自动创建账号</text>
      <text class="footer-text">验证码：123456</text>
    </view>
  </view>
</view>
