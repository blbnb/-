<!-- 登录方式选择页面 -->
<view class="login-container">
  <!-- 背景装饰 - 优化版 -->
  <view class="bg-decoration">
    <!-- 渐变光晕 -->
    <view class="bg-glow glow-1"></view>
    <view class="bg-glow glow-2"></view>
    <view class="bg-glow glow-3"></view>
    
    <!-- 装饰圆点 -->
    <view class="decor-dot dot-1"></view>
    <view class="decor-dot dot-2"></view>
    <view class="decor-dot dot-3"></view>
    <view class="decor-dot dot-4"></view>
    
    <!-- 波浪线条 -->
    <view class="wave-line wave-1"></view>
    <view class="wave-line wave-2"></view>
    <view class="wave-line wave-3"></view>
  </view>

  <!-- 主要内容区域 -->
  <view class="login-content">
    <!-- Logo 和标题区域 -->
    <view class="logo-section">
      <view class="logo-wrapper">
        <image class="app-logo" src="/Default.jpg" mode="aspectFill"></image>
      </view>
      <text class="app-name">校园书屋</text>
      <text class="app-slogan">让知识传递，让价值延续</text>
    </view>

    <!-- 登录方式选择 -->
    <view class="login-options">
      <!-- 微信一键登录 -->
      <view class="login-option-item" bindtap="selectWechatLogin">
        <view class="option-icon wechat-icon">
          <image src="data:image/svg+xml;base64," mode="aspectFit"></image>
        </view>
        <view class="option-content">
          <text class="option-title">微信一键登录</text>
          <text class="option-desc">安全便捷，推荐使用</text>
        </view>
        <view class="option-arrow">›</view>
      </view>

      <!-- 手机号登录 -->
      <view class="login-option-item" bindtap="selectPhoneLogin">
        <view class="option-icon phone-icon">
          <text>📱</text>
        </view>
        <view class="option-content">
          <text class="option-title">手机号登录</text>
          <text class="option-desc">传统方式，验证登录</text>
        </view>
        <view class="option-arrow">›</view>
      </view>
    </view>

    <!-- 用户协议 -->
    <view class="agreement-section">
      <view class="checkbox-wrapper" bindtap="toggleAgreement">
        <view class="checkbox {{agreementAccepted ? 'checked' : ''}}">
          <text wx:if="{{agreementAccepted}}" class="checkmark">✓</text>
        </view>
      </view>
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" bindtap="showUserAgreement">《用户协议》</text>
      <text class="agreement-text">和</text>
      <text class="agreement-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
    </view>

    <!-- 底部提示 -->
    <view class="login-footer">
      <text class="footer-text">登录即代表您同意我们的服务条款</text>
    </view>
  </view>
</view>

<!-- 用户协议弹窗 -->
<view class="modal-mask" wx:if="{{showAgreementModal}}" bindtap="closeAgreementModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">用户协议</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <text class="modal-text">
        欢迎使用校园书屋小程序！

        在您使用本服务前，请仔细阅读以下协议：

        一、服务条款
        1. 本小程序提供校园图书交易服务
        2. 用户应当遵守相关法律法规
        3. 不得发布违法违规信息

        二、用户权利与义务
        1. 用户有权使用本小程序进行交易
        2. 应当保证发布信息真实有效
        3. 尊重他人知识产权

        三、隐私保护
        1. 本小程序重视用户隐私保护
        2. 不会泄露用户个人信息
        3. 依法保护用户数据安全

        四、免责声明
        1. 因不可抗力导致的服务中断不承担责任
        2. 用户交易风险自行承担
        3. 本小程序保留最终解释权

        请您务必阅读并理解本协议的全部内容。
      </text>
    </scroll-view>
    <view class="modal-footer">
      <button class="modal-btn-cancel" bindtap="closeAgreementModal">取消</button>
      <button class="modal-btn-confirm" bindtap="acceptAgreement">同意</button>
    </view>
  </view>
</view>

<!-- 隐私政策弹窗 -->
<view class="modal-mask" wx:if="{{showPrivacyModal}}" bindtap="closePrivacyModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">隐私政策</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <text class="modal-text">
        校园书屋隐私政策

        我们重视您的隐私保护，请您仔细阅读本政策：

        一、信息收集
        1. 我们可能收集您的手机号、昵称等基本信息
        2. 收集您的交易记录用于订单管理
        3. 收集设备信息用于安全验证

        二、信息使用
        1. 用于提供服务和改进用户体验
        2. 用于身份验证和安全保障
        3. 不会向第三方泄露您的信息

        三、信息保护
        1. 采用加密技术保护您的信息
        2. 建立安全管理制度
        3. 定期进行安全审计

        四、您的权利
        1. 有权查询、更正您的信息
        2. 有权注销账号
        3. 有权撤回授权

        请确保您已阅读并同意本政策。
      </text>
    </scroll-view>
    <view class="modal-footer">
      <button class="modal-btn-cancel" bindtap="closePrivacyModal">取消</button>
      <button class="modal-btn-confirm" bindtap="acceptPrivacy">同意</button>
    </view>
  </view>
</view>
