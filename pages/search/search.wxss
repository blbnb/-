/* 搜索页面样式 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-right: 20rpx;
}

.icon-search {
  font-size: 28rpx;
  color: #999999;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  background-color: transparent;
}

.placeholder {
  color: #999999;
}

.search-btn {
  font-size: 28rpx;
  color: #4F46E5;
  font-weight: 500;
}

/* 内容区域 */
.content {
  padding: 20rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 无结果 */
.no-results {
  text-align: center;
  padding: 100rpx 0;
}

.no-results-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  display: block;
}

.no-results-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.no-results-hint {
  font-size: 28rpx;
  color: #999999;
  display: block;
}

/* 搜索结果 */
.search-results {
  margin-bottom: 20rpx;
}

.results-header {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.book-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.book-item {
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.book-img-container {
  position: relative;
  width: 100%;
  padding-top: 140%; /* 固定宽高比 */
  overflow: hidden;
}

.book-img-container image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.book-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background-color: #FF6B6B;
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
}

.book-info {
  padding: 16rpx;
}

.book-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-author {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.price-container {
  display: flex;
  align-items: center;
}

.book-price {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 500;
  margin-right: 10rpx;
}

.original-price {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-right: 10rpx;
}

.discount-tag {
  font-size: 20rpx;
  color: #FF6B6B;
  background-color: rgba(255, 107, 107, 0.1);
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
}

/* 默认显示区域 */
.search-default {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.clear-btn {
  font-size: 24rpx;
  color: #999999;
}

.history-tags, .hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.history-tag, .hot-tag {
  font-size: 28rpx;
  color: #666666;
  background-color: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
}

.hot-tag {
  background-color: #e6f7ff;
  color: #4F46E5;
}