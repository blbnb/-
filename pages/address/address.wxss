/* pages/address/address.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-left {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.header-right {
  width: 60rpx;
}

.address-list {
  padding-top: 120rpx;
}

.address-item {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.address-item.selectable {
  padding-right: 80rpx;
}

.address-item.selected {
  border: 2rpx solid #07c160;
  background-color: #f0f9f4;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 20rpx;
}

.phone {
  font-size: 30rpx;
  color: #666;
  margin-right: 20rpx;
}

.default {
  font-size: 24rpx;
  color: #07c160;
  background-color: #f0f9f4;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.address-content {
  font-size: 30rpx;
  color: #666;
  line-height: 44rpx;
  margin-bottom: 20rpx;
}

.address-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  font-size: 28rpx;
  color: #666;
  padding: 0 20rpx;
}

.action-btn.delete {
  color: #ff4757;
}

.action-divider {
  width: 1rpx;
  height: 24rpx;
  background-color: #eee;
}

.select-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
  color: #999;
  font-size: 30rpx;
}

.add-btn {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 690rpx;
  height: 90rpx;
  background-color: #07c160;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.3);
}

.add-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}