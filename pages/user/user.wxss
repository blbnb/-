/* 个人中心页面样式 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 用户信息区域 */
.user-info-section {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #4F46E5;
  color: #fff;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
  margin-left: 30rpx;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.user-id {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-college {
  font-size: 24rpx;
  opacity: 0.9;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
}

.user-level {
  font-size: 24rpx;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.user-actions {
  display: flex;
  align-items: center;
}

.notification-icon {
  position: relative;
  font-size: 44rpx;
  margin-right: 20rpx;
  padding: 10rpx;
}

.notification-badge {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #FF4757;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
}

.user-arrow {
  padding: 20rpx;
}

.user-arrow .icon {
  font-size: 40rpx;
  opacity: 0.8;
}

/* 用户统计区域 */
.stats-section {
  background-color: #fff;
  margin: 20rpx 0;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  border-radius: 10rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4F46E5;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
}

.stat-divider {
  width: 2rpx;
  background-color: #f0f0f0;
  margin: 0 20rpx;
}

/* 订单状态区域 */
.order-status-section {
  background-color: #fff;
  margin: 20rpx 0;
  padding: 30rpx;
  border-radius: 10rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 28rpx;
  color: #999;
}

.order-states {
  display: flex;
  justify-content: space-around;
}

.order-state-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon-wrapper {
  position: relative;
  margin-bottom: 15rpx;
}

.order-icon {
  font-size: 60rpx;
}

.order-badge {
  position: absolute;
  top: -10rpx;
  right: -20rpx;
  background-color: #FF4757;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
}

.order-text {
  font-size: 26rpx;
  color: #333;
}

/* 功能菜单区域 */
.menu-section {
  background-color: #fff;
  margin: 20rpx 0;
  border-radius: 10rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  position: relative;
}

.menu-badge {
  position: absolute;
  right: 60rpx;
  background-color: #FF4757;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 30rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #999;
  font-size: 32rpx;
}

/* 退出登录按钮 */
.logout-btn {
  margin: 40rpx 30rpx;
  background-color: #fff;
  color: #ff4757;
  border-radius: 10rpx;
  font-size: 32rpx;
  border: none;
}

.logout-btn:active {
  background-color: #f5f5f5;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
}

.version-info text {
  font-size: 26rpx;
  color: #999;
}