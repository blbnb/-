<!-- 个人中心页面 -->
<view class="page">
  <!-- 用户信息区域 -->
  <view class="user-info-section">
    <view class="user-avatar" bindtap="handleAvatarTap">
      <image src="{{userInfo && userInfo.avatarUrl ? userInfo.avatarUrl : '/Default.jpg'}}" mode="aspectFill"></image>
    </view>
    <view class="user-details" bindtap="handleAvatarTap">
      <text class="user-name">{{userName || '点击登录'}}</text>
      <text class="user-id">{{userID || '登录后查看账号信息'}}</text>
      <view class="user-meta" wx:if="{{isLoggedIn}}">
        <text class="user-college">{{userInfo && userInfo.college ? userInfo.college : '未设置学院'}}</text>
        <text class="user-level">{{userInfo && userInfo.level ? userInfo.level : '普通会员'}}</text>
      </view>
    </view>
    <view class="user-actions">
      <view class="notification-icon" bindtap="goToNotifications">
        <text class="icon">🔔</text>
        <view class="notification-badge" wx:if="{{notificationCount > 0}}">{{notificationCount}}</view>
      </view>
      <view class="user-arrow" bindtap="handleAvatarTap">
        <text class="icon">›</text>
      </view>
    </view>
  </view>

  <!-- 订单状态区域 -->
  <view class="order-status-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="section-more" bindtap="goToOrders">全部订单 ›</text>
    </view>
    <view class="order-states">
      <view class="order-state-item" bindtap="goToOrderList" data-status="pending">
        <view class="order-icon-wrapper">
          <view class="order-icon">📦</view>
          <view class="order-badge" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
        </view>
        <text class="order-text">待付款</text>
      </view>
      <view class="order-state-item" bindtap="goToOrderList" data-status="paid">
        <view class="order-icon-wrapper">
          <view class="order-icon">🚚</view>
          <view class="order-badge" wx:if="{{orderCounts.paid > 0}}">{{orderCounts.paid}}</view>
        </view>
        <text class="order-text">待发货</text>
      </view>
      <view class="order-state-item" bindtap="goToOrderList" data-status="shipped">
        <view class="order-icon-wrapper">
          <view class="order-icon">📮</view>
          <view class="order-badge" wx:if="{{orderCounts.shipped > 0}}">{{orderCounts.shipped}}</view>
        </view>
        <text class="order-text">待收货</text>
      </view>
      <view class="order-state-item" bindtap="goToOrderList" data-status="received">
        <view class="order-icon-wrapper">
          <view class="order-icon">⭐</view>
          <view class="order-badge" wx:if="{{orderCounts.received > 0}}">{{orderCounts.received}}</view>
        </view>
        <text class="order-text">待评价</text>
      </view>
    </view>
  </view>

  <!-- 用户统计区域 -->
  <view class="stats-section" wx:if="{{isLoggedIn}}">
    <view class="stat-item" bindtap="goToMyBooks">
      <text class="stat-value">{{userStats.booksCount}}</text>
      <text class="stat-label">我的图书</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToFavorites">
      <text class="stat-value">{{userStats.favoritesCount}}</text>
      <text class="stat-label">我的收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToHistory">
      <text class="stat-value">{{userStats.historyCount}}</text>
      <text class="stat-label">浏览历史</text>
    </view>
  </view>

  <!-- 功能菜单区域 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToNotifications">
      <text class="menu-icon">🔔</text>
      <text class="menu-text">消息通知</text>
      <text class="menu-arrow">›</text>
      <view class="menu-badge" wx:if="{{notificationCount > 0}}">{{notificationCount}}</view>
    </view>
    <view class="menu-item" bindtap="goToCoupons">
      <text class="menu-icon">🎫</text>
      <text class="menu-text">优惠券</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPoints">
      <text class="menu-icon">🎯</text>
      <text class="menu-text">我的积分</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="menu-item" bindtap="goToPublishBook">
      <text class="menu-icon">➕</text>
      <text class="menu-text">发表图书</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyBooks">
      <text class="menu-icon">📚</text>
      <text class="menu-text">我的图书</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFavorites">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToHistory">
      <text class="menu-icon">🕐</text>
      <text class="menu-text">浏览历史</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">在线客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <text class="menu-icon">❓</text>
      <text class="menu-text">帮助与反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <button class="logout-btn" bindtap="logout" wx:if="{{isLoggedIn}}">退出登录</button>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本 1.0.0</text>
  </view>
</view>