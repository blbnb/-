/* 购物车页面样式 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 30rpx 20rpx;
  background-color: #fff;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.content {
  flex: 1;
  padding: 20rpx;
}

/* 购物车列表 */
.cart-list {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
}

.cart-item {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: #fff;
}

.checkbox-inner {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: transparent;
  color: #ff6600;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.cart-item image {
  width: 160rpx;
  height: 220rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.cart-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 220rpx;
}

.book-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 28rpx;
  color: #333;
}

.book-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 10rpx;
}

.book-meta {
  margin-bottom: 10rpx;
}

.condition-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #f0f9ff;
  color: #0ea5e9;
  font-size: 22rpx;
  border-radius: 4rpx;
  border: 1rpx solid #bae6fd;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.btn-minus,
.btn-plus {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #333;
}

.btn-minus.disabled {
  color: #ccc;
  border-color: #eee;
}

.quantity {
  margin: 0 30rpx;
  font-size: 28rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

.btn-delete {
  font-size: 26rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-shopping {
  background-color: #4F46E5;
  color: #fff;
  border-radius: 60rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  border: none;
}

.go-shopping:active {
  background-color: #4338CA;
}

/* 底部结算栏 */
.footer {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  background-color: #fff;
  border-top: 2rpx solid #f0f0f0;
  height: 100rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  font-size: 30rpx;
  color: #666;
  margin-left: 12rpx;
}

.total {
  flex: 1;
  text-align: right;
  margin-right: 30rpx;
}

.total text {
  font-size: 30rpx;
  color: #333;
  font-weight: normal;
}

.checkout-btn {
  background-color: #ff6600;
  color: #fff;
  border-radius: 10rpx;
  padding: 0;
  font-size: 32rpx;
  border: none;
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  white-space: nowrap;
}

.checkout-btn:active {
  background-color: #ff5000;
}

.checkout-btn[disabled] {
  background-color: #ccc;
  color: #fff;
}