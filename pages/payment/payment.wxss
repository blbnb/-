/* 页面容器 */
.container {
  background-color: #ededed;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 30rpx;
  background-color: #ededed;
}

.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #000;
  font-weight: 300;
}

.title {
  font-size: 34rpx;
  font-weight: 500;
  color: #000;
}

.placeholder {
  width: 60rpx;
}

/* 支付金额区域 */
.pay-amount-section {
  background-color: #ededed;
  padding: 40rpx 0 60rpx;
  text-align: center;
}

.pay-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.amount-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.currency {
  font-size: 48rpx;
  color: #000;
  font-weight: 500;
  margin-right: 10rpx;
  margin-top: 10rpx;
}

.amount {
  font-size: 100rpx;
  color: #000;
  font-weight: 500;
  line-height: 1;
}

.merchant-name {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 支付方式选择 */
.payment-methods {
  background-color: #fff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.method-title {
  font-size: 28rpx;
  color: #999;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.method-item:last-child {
  border-bottom: none;
}

.method-item.selected {
  background-color: #f9f9f9;
}

.method-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.method-icon.balance {
  background-color: #ff9500;
}

.method-icon.lqt {
  background-color: #ff6b00;
}

.method-icon.card {
  background-color: #ff4757;
}

.icon-text {
  font-size: 32rpx;
}

.method-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.method-name {
  font-size: 30rpx;
  color: #000;
  margin-bottom: 6rpx;
}

.method-desc {
  font-size: 24rpx;
  color: #999;
}

.method-check {
  width: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.check-circle.checked {
  background-color: #07c160;
  border-color: #07c160;
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 支付按钮 */
.pay-button-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 30rpx;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.pay-btn {
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-btn::after {
  border: none;
}

.pay-btn.loading {
  background-color: #9ed99d;
}

.pay-btn[disabled] {
  background-color: #9ed99d;
}

/* 密码输入弹窗 */
.password-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.password-popup.show {
  visibility: visible;
  opacity: 1;
}

.popup-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #f5f5f5;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.password-popup.show .popup-content {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 36rpx;
  color: #999;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #000;
}

.popup-amount {
  background-color: #fff;
  padding: 40rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-amount .currency {
  font-size: 40rpx;
  color: #000;
}

.popup-amount .amount {
  font-size: 72rpx;
  color: #000;
  font-weight: 500;
}

/* 密码输入框 */
.password-box {
  background-color: #fff;
  padding: 40rpx 60rpx;
  position: relative;
}

.password-dots {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.dot {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
}

.dot.filled::after {
  content: '';
  width: 20rpx;
  height: 20rpx;
  background-color: #000;
  border-radius: 50%;
}

.password-input {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  z-index: 10;
}

.password-hint {
  background-color: #fff;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

/* 数字键盘 */
.number-keyboard {
  background-color: #f5f5f5;
  padding: 10rpx;
}

.keyboard-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.keyboard-row:last-child {
  margin-bottom: 0;
}

.key {
  flex: 1;
  height: 100rpx;
  background-color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #000;
  font-weight: 500;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.key:active {
  background-color: #e0e0e0;
}

.key.empty {
  background-color: transparent;
  box-shadow: none;
}

.key.delete {
  background-color: #fff;
}

.delete-icon {
  font-size: 36rpx;
  color: #666;
}

/* 支付成功弹窗 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.success-icon-wrapper {
  margin-bottom: 40rpx;
}

.success-circle {
  width: 160rpx;
  height: 160rpx;
  background-color: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-check {
  font-size: 80rpx;
  color: #fff;
  font-weight: bold;
}

.success-title {
  font-size: 40rpx;
  color: #000;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.success-amount {
  font-size: 72rpx;
  color: #000;
  font-weight: 500;
  margin-bottom: 80rpx;
}

.success-actions {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  width: 100%;
}

.action-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 1rpx solid #e0e0e0;
  color: #333;
  background-color: #fff;
}

.action-btn.primary {
  background-color: #07c160;
  color: #fff;
  border: none;
}

.action-btn:active {
  opacity: 0.8;
}

/* 密码错误提示 */
.error-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 3000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.error-toast.show {
  opacity: 1;
  visibility: visible;
}

.error-content {
  background-color: rgba(0, 0, 0, 0.8);
  padding: 30rpx 60rpx;
  border-radius: 12rpx;
}

.error-text {
  font-size: 30rpx;
  color: #fff;
}
