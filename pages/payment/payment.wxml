<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="title">支付</view>
    <view class="placeholder"></view>
  </view>

  <!-- 支付金额区域 -->
  <view class="pay-amount-section">
    <view class="pay-label">支付金额</view>
    <view class="amount-row">
      <text class="currency">¥</text>
      <text class="amount">{{orderInfo.totalPrice}}</text>
    </view>
    <view class="merchant-name">校园图书</view>
  </view>

  <!-- 支付方式选择 -->
  <view class="payment-methods">
    <view class="method-title">支付方式</view>
    
    <!-- 零钱 -->
    <view class="method-item {{selectedMethod === 'balance' ? 'selected' : ''}}" bindtap="selectMethod" data-method="balance">
      <view class="method-icon balance">
        <text class="icon-text">💰</text>
      </view>
      <view class="method-info">
        <text class="method-name">零钱</text>
        <text class="method-desc">余额 ¥{{balance}}</text>
      </view>
      <view class="method-check">
        <view class="check-circle {{selectedMethod === 'balance' ? 'checked' : ''}}">
          <text wx:if="{{selectedMethod === 'balance'}}" class="check-icon">✓</text>
        </view>
      </view>
    </view>

    <!-- 零钱通 -->
    <view class="method-item {{selectedMethod === 'lqt' ? 'selected' : ''}}" bindtap="selectMethod" data-method="lqt">
      <view class="method-icon lqt">
        <text class="icon-text">💎</text>
      </view>
      <view class="method-info">
        <text class="method-name">零钱通</text>
        <text class="method-desc">收益更高 随时可取</text>
      </view>
      <view class="method-check">
        <view class="check-circle {{selectedMethod === 'lqt' ? 'checked' : ''}}">
          <text wx:if="{{selectedMethod === 'lqt'}}" class="check-icon">✓</text>
        </view>
      </view>
    </view>

    <!-- 银行卡 -->
    <view class="method-item {{selectedMethod === 'card' ? 'selected' : ''}}" bindtap="selectMethod" data-method="card">
      <view class="method-icon card">
        <text class="icon-text">💳</text>
      </view>
      <view class="method-info">
        <text class="method-name">招商银行储蓄卡(8888)</text>
        <text class="method-desc">快捷支付</text>
      </view>
      <view class="method-check">
        <view class="check-circle {{selectedMethod === 'card' ? 'checked' : ''}}">
          <text wx:if="{{selectedMethod === 'card'}}" class="check-icon">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付按钮 -->
  <view class="pay-button-section">
    <button class="pay-btn {{loading ? 'loading' : ''}}" bindtap="confirmPayment" disabled="{{loading}}">
      <text wx:if="{{!loading}}">立即支付</text>
      <text wx:if="{{loading}}">支付中...</text>
    </button>
  </view>

  <!-- 支付密码输入弹窗（仿微信支付键盘） -->
  <view class="password-popup {{showPasswordModal ? 'show' : ''}}">
    <view class="popup-overlay" bindtap="cancelPayment"></view>
    <view class="popup-content">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <view class="close-btn" bindtap="cancelPayment">
          <text class="close-icon">✕</text>
        </view>
        <text class="popup-title">输入支付密码</text>
        <view class="placeholder"></view>
      </view>

      <!-- 金额显示 -->
      <view class="popup-amount">
        <text class="currency">¥</text>
        <text class="amount">{{orderInfo.totalPrice}}</text>
      </view>

      <!-- 密码输入框 -->
      <view class="password-box">
        <view class="password-dots">
          <view class="dot {{passwordLength > 0 ? 'filled' : ''}}"></view>
          <view class="dot {{passwordLength > 1 ? 'filled' : ''}}"></view>
          <view class="dot {{passwordLength > 2 ? 'filled' : ''}}"></view>
          <view class="dot {{passwordLength > 3 ? 'filled' : ''}}"></view>
          <view class="dot {{passwordLength > 4 ? 'filled' : ''}}"></view>
          <view class="dot {{passwordLength > 5 ? 'filled' : ''}}"></view>
        </view>
        <input 
          class="password-input" 
          type="number" 
          maxlength="6" 
          focus="{{showPasswordModal}}"
          bindinput="onPasswordInput"
          value="{{paymentPassword}}"
        />
      </view>

      <!-- 提示信息 -->
      <view class="password-hint">
        <text>默认密码：123456</text>
      </view>

      <!-- 数字键盘 -->
      <view class="number-keyboard">
        <view class="keyboard-row">
          <view class="key" bindtap="inputNumber" data-num="1">1</view>
          <view class="key" bindtap="inputNumber" data-num="2">2</view>
          <view class="key" bindtap="inputNumber" data-num="3">3</view>
        </view>
        <view class="keyboard-row">
          <view class="key" bindtap="inputNumber" data-num="4">4</view>
          <view class="key" bindtap="inputNumber" data-num="5">5</view>
          <view class="key" bindtap="inputNumber" data-num="6">6</view>
        </view>
        <view class="keyboard-row">
          <view class="key" bindtap="inputNumber" data-num="7">7</view>
          <view class="key" bindtap="inputNumber" data-num="8">8</view>
          <view class="key" bindtap="inputNumber" data-num="9">9</view>
        </view>
        <view class="keyboard-row">
          <view class="key empty"></view>
          <view class="key" bindtap="inputNumber" data-num="0">0</view>
          <view class="key delete" bindtap="deleteNumber">
            <text class="delete-icon">⌫</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付成功弹窗 -->
  <view class="success-modal" wx:if="{{showSuccessModal}}">
    <view class="success-content">
      <view class="success-icon-wrapper">
        <view class="success-circle">
          <text class="success-check">✓</text>
        </view>
      </view>
      <text class="success-title">支付成功</text>
      <text class="success-amount">¥{{orderInfo.totalPrice}}</text>
      <view class="success-actions">
        <view class="action-btn primary" bindtap="goToOrders">
          <text>查看订单</text>
        </view>
        <view class="action-btn" bindtap="goBack">
          <text>完成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 密码错误提示 -->
  <view class="error-toast {{showErrorToast ? 'show' : ''}}">
    <view class="error-content">
      <text class="error-text">密码错误</text>
    </view>
  </view>
</view>
