<!-- pages/payment/payment.wxml -->
<view class="container">
  <!-- 头部导航栏 -->
  <view class="header">
    <view class="back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="title">确认订单</view>
    <view class="placeholder"></view>
  </view>

  <!-- 订单信息 -->
  <view class="order-info">
    <view class="order-item">
      <text class="label">订单编号</text>
      <text class="value">{{orderInfo.orderNo}}</text>
    </view>
    <view class="order-item">
      <text class="label">收货地址</text>
      <text class="value">{{orderInfo.address}}</text>
    </view>
    <view class="order-item">
      <text class="label">联系电话</text>
      <text class="value">{{orderInfo.phone}}</text>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="goods-section">
    <view class="section-title">商品信息</view>
    <view class="goods-item" wx:for="{{orderInfo.items}}" wx:key="index">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="goods-info">
        <text class="goods-title">{{item.title}}</text>
        <text class="goods-author">{{item.author}}</text>
        <view class="goods-price-row">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-quantity">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="price-section">
    <view class="price-item">
      <text class="label">商品总价</text>
      <text class="value">¥{{orderInfo.totalPrice}}</text>
    </view>
    <view class="price-item">
      <text class="label">运费</text>
      <text class="value">¥0.00</text>
    </view>
    <view class="price-item total">
      <text class="label">实付金额</text>
      <text class="value total-price">¥{{orderInfo.totalPrice}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-method">
      <image class="payment-icon" src="https://img.icons8.com/color/48/000000/wechat-pay.png"></image>
      <text class="payment-name">微信支付</text>
      <text class="payment-arrow">→</text>
    </view>
  </view>

  <!-- 支付二维码 -->
  <view class="qr-code-section">
    <view class="qr-code-container">
      <image class="qr-code" src="{{paymentQRCode}}" mode="aspectFit"></image>
      <text class="qr-code-text">识别此收款码</text>
      <text class="qr-code-amount">向"校园图书"付款 ¥{{orderInfo.totalPrice}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="total-price-section">
      <text class="total-label">实付金额：</text>
      <text class="total-amount">¥{{orderInfo.totalPrice}}</text>
    </view>
    <view class="pay-button" bindtap="confirmPayment">
      <text class="pay-button-text">识别并支付</text>
    </view>
  </view>

  <!-- 支付成功提示 -->
  <view class="success-modal" wx:if="{{showSuccessModal}}">
    <view class="success-content">
      <image class="success-icon" src="https://img.icons8.com/color/96/000000/ok--v1.png"></image>
      <text class="success-text">支付成功</text>
      <text class="success-subtext">订单已确认</text>
      <view class="success-button" bindtap="goToOrders">
        <text class="success-button-text">查看订单</text>
      </view>
    </view>
  </view>
</view>