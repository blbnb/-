/* pages/help/help.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 页面头部样式 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.empty {
  width: 60rpx;
}

/* 通用section样式 */
.section {
  margin-top: 20rpx;
  padding-top: 120rpx;
}

.section:first-child {
  padding-top: 120rpx;
}

.section:not(:first-child) {
  padding-top: 0;
}

.section-title {
  padding: 20rpx 30rpx;
  background-color: #f5f5f5;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 常见问题样式 */
.faq-list {
  background-color: #fff;
}

.faq-item {
  border-bottom: 1rpx solid #f0f0f0;
  overflow: hidden;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
}

.faq-question {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  padding-right: 30rpx;
  line-height: 40rpx;
}

.faq-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s;
}

.faq-icon.rotate {
  transform: rotate(180deg);
}

.faq-icon text {
  font-size: 24rpx;
  color: #999;
}

.faq-answer {
  padding: 0 30rpx 28rpx;
  background-color: #fafafa;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s, padding 0.3s;
}

.faq-item.expanded .faq-answer {
  max-height: 500rpx;
  padding: 0 30rpx 28rpx;
}

.faq-answer text {
  font-size: 26rpx;
  color: #666;
  line-height: 42rpx;
  white-space: pre-wrap;
}

/* 联系客服样式 */
.contact-info {
  background-color: #fff;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.contact-icon image {
  width: 40rpx;
  height: 40rpx;
}

.contact-content {
  flex: 1;
}

.contact-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 4rpx;
  display: block;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.contact-btn {
  background-color: #ff6600;
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 52rpx;
  line-height: 52rpx;
}

.contact-btn::after {
  border: none;
}

/* 意见反馈样式 */
.feedback-form {
  background-color: #fff;
  padding: 0 30rpx 30rpx;
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.form-control {
  position: relative;
}

/* 反馈类型选择 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.radio-item {
  margin-right: 40rpx;
  margin-bottom: 10rpx;
}

radio {
  transform: scale(0.8);
}

radio-group radio {
  margin-right: 10rpx;
}

/* 文本输入框 */
.input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 0;
}

/* 文本域 */
.textarea {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  line-height: 42rpx;
  min-height: 200rpx;
  padding: 20rpx 0;
  resize: none;
}

.char-count {
  position: absolute;
  bottom: 0;
  right: 0;
  font-size: 24rpx;
  color: #999;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 300;
}

.add-image {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-image image {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 10rpx;
}

.add-image text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 32rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 40rpx 0 20rpx;
}

.submit-btn {
  background-color: #ff6600;
  color: #fff;
  border-radius: 60rpx;
  font-size: 32rpx;
  padding: 0;
  height: 90rpx;
  line-height: 90rpx;
  width: 100%;
}

.submit-btn::after {
  border: none;
}

/* 底部链接 */
.bottom-links {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.link-item {
  font-size: 24rpx;
  color: #666;
  padding: 0 20rpx;
}

.link-divider {
  font-size: 24rpx;
  color: #ddd;
}

/* 响应式调整 */
@media screen and (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }
  
  .header {
    max-width: 750rpx;
    left: 50%;
    transform: translateX(-50%);
  }
}