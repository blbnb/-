/* pages/userAgreement/userAgreement.wxss */
.container {
  width: 100%;
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e5e5e5;
  text-align: center;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.agreement-content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.agreement-text {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.agreement-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.agreement-section-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
}

.agreement-paragraph {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 15rpx;
  text-indent: 44rpx;
}

.bottom-marker {
  margin-top: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e5e5;
  text-align: center;
}

.bottom-text {
  font-size: 24rpx;
  color: #07c160;
  font-weight: bold;
}

.footer {
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.countdown {
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: #666;
}

/* 勾选框样式 */
.agreement-checkbox {
  margin: 20rpx 0;
  padding: 0 40rpx;
}

.checkbox-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.checkbox-label checkbox {
  margin-right: 12rpx;
  transform: scale(1.2);
}

.buttons {
  display: flex;
  gap: 20rpx;
}

.disagree-btn {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #ccc;
  background-color: #fff;
  color: #666;
  font-size: 28rpx;
  border-radius: 10rpx;
}

.agree-btn {
  flex: 2;
  height: 80rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 10rpx;
}

.agree-btn:disabled {
  background-color: #ccc;
  color: #fff;
}