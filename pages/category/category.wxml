<view class="page">
  <view class="header">
    <view class="empty"></view>
    <view class="title">{{categoryName}}</view>
    <view class="empty"></view>
  </view>
  
  <view class="content">
    <view class="grade-sidebar">
      <view class="grade-list">
        <view 
          wx:for="{{grades}}" 
          wx:key="name"
          class="grade-item {{selectedGrade === item.name ? 'selected' : ''}}"
          data-name="{{item.name}}"
          bindtap="switchGrade"
        >
          {{item.name}}
        </view>
      </view>
    </view>
    
    <view class="course-content">
      <!-- 学期选择区域 -->
      <view class="semester-tabs">
        <view 
          wx:for="{{currentGrade.semesters}}" 
          wx:key="name"
          class="semester-tab {{selectedSemester === item.name ? 'selected' : ''}}"
          data-name="{{item.name}}"
          bindtap="switchSemester"
        >
          {{item.name}}
        </view>
      </view>
      
      <!-- 课程列表 -->
      <view class="course-list">
        <view wx:if="{{currentSemester.books.length > 0}}" class="course-grid">
          <view 
            wx:for="{{currentSemester.books}}" 
            wx:key="id"
            class="course-item"
            data-id="{{item.id}}"
            bindtap="goToDetail"
          >
            <view class="course-img">
              <image src="{{item.image}}" mode="aspectFill"></image>
            </view>
            <view class="course-info">
              <view class="course-title">{{item.title}}</view>
              <view class="course-price">¥{{item.price}}</view>
            </view>
          </view>
        </view>
        
        <view wx:else class="empty-tip">
          <text>暂无课程数据</text>
        </view>
      </view>
    </view>
  </view>
</view>