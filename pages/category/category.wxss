/* pages/category/category.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 头部样式 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  padding: 0 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  width: 80rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  width: 80rpx;
}

/* 内容区域 */
.content {
  display: flex;
  margin-top: 100rpx;
  height: calc(100vh - 100rpx);
}

/* 左侧年级列表 */
.grade-sidebar {
  width: 180rpx;
  background-color: #f5f5f5;
  overflow-y: auto;
}

.grade-list {
  padding: 20rpx 0;
}

.grade-item {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  position: relative;
}

.grade-item.selected {
  color: #1989fa;
  background-color: #fff;
  font-weight: 600;
}

.grade-item.selected::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: #1989fa;
  border-radius: 0 3rpx 3rpx 0;
}

/* 右侧内容区域 */
.course-content {
  flex: 1;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

/* 学期切换标签 */
.semester-tabs {
  display: flex;
  height: 80rpx;
  border-bottom: 1rpx solid #eee;
  background-color: #fff;
}

.semester-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.semester-tab.selected {
  color: #1989fa;
  font-weight: 600;
}

.semester-tab.selected::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #1989fa;
  border-radius: 3rpx;
}

/* 课程列表 */
.course-list {
  flex: 1;
  padding: 20rpx;
}

.course-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.course-item {
  width: calc(50% - 10rpx);
  margin-bottom: 30rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.course-img {
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.course-img image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s;
}

.course-item:active .course-img image {
  transform: scale(0.98);
}

.course-info {
  padding: 16rpx;
}

.course-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 8rpx;
  height: 80rpx;
}

.course-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 600;
}

/* 空状态 */
.empty-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  color: #999;
  font-size: 28rpx;
}

/* 滚动条样式 */
.grade-sidebar::-webkit-scrollbar,
.course-content::-webkit-scrollbar {
  width: 4rpx;
  height: 4rpx;
}

.grade-sidebar::-webkit-scrollbar-track,
.course-content::-webkit-scrollbar-track {
  background: transparent;
}

.grade-sidebar::-webkit-scrollbar-thumb,
.course-content::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.1);
  border-radius: 2rpx;
}

.grade-sidebar::-webkit-scrollbar-thumb:hover,
.course-content::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 0, 0, 0.2);
}