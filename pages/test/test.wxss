/* pages/test/test.wxss */
.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.status {
  font-size: 28rpx;
  font-weight: bold;
}

.status.testing {
  color: #ff9900;
}

.status.idle {
  color: #07c160;
}

.refresh-btn {
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  height: auto;
  line-height: 1.5;
}

.test-list {
  margin-bottom: 40rpx;
}

.test-item {
  background: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.test-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.test-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.test-time {
  font-size: 24rpx;
  color: #999;
}

.test-result {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 8rpx;
}

.test-result.success {
  background: #e8f5e9;
}

.test-result.fail {
  background: #ffebee;
}

.result-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  font-weight: bold;
}

.test-result.success .result-icon {
  color: #07c160;
}

.test-result.fail .result-icon {
  color: #f44336;
}

.result-message {
  font-size: 28rpx;
  flex: 1;
}

.test-result.success .result-message {
  color: #2e7d32;
}

.test-result.fail .result-message {
  color: #c62828;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.tips {
  background: #fff3e0;
  border-radius: 10rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #e65100;
  margin-bottom: 15rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #bf360c;
  margin-bottom: 10rpx;
  line-height: 1.6;
}
