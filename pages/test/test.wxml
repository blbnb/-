<!--pages/test/test.wxml-->
<view class="container">
  <view class="header">
    <view class="title">小程序连接测试</view>
    <view class="subtitle">检测后端服务连接状态</view>
  </view>

  <view class="status-bar">
    <view class="status {{testing ? 'testing' : 'idle'}}">
      {{testing ? '测试中...' : '测试完成'}}
    </view>
    <button class="refresh-btn" bindtap="onRefresh" disabled="{{testing}}">
      重新测试
    </button>
  </view>

  <view class="test-list">
    <view class="test-item" wx:for="{{testResults}}" wx:key="index">
      <view class="test-header">
        <view class="test-name">{{item.name}}</view>
        <view class="test-time">{{item.time}}</view>
      </view>
      <view class="test-result {{item.success ? 'success' : 'fail'}}">
        <view class="result-icon">{{item.success ? '✓' : '✗'}}</view>
        <view class="result-message">{{item.message}}</view>
      </view>
    </view>

    <view class="empty" wx:if="{{testResults.length === 0}}">
      暂无测试结果
    </view>
  </view>

  <view class="tips">
    <view class="tips-title">如果测试失败：</view>
    <view class="tips-item">1. 检查"不校验合法域名"是否开启</view>
    <view class="tips-item">2. 检查后端服务是否运行</view>
    <view class="tips-item">3. 检查防火墙设置</view>
    <view class="tips-item">4. 确认 IP 地址是否正确</view>
  </view>
</view>
