<!-- pages/checkout/checkout.wxml -->
<view class="page">
  <view class="header">
    <text class="title">确认订单</text>
  </view>

  <!-- 地址信息 -->
  <view class="address-section" bindtap="selectAddress">
    <view class="address-content">
      <view class="address-header">
        <text class="name">{{selectedAddress ? selectedAddress.name : '未设置'}}</text>
        <text class="phone">{{selectedAddress ? selectedAddress.phone : ''}}</text>
      </view>
      <view class="address-detail">
        {{selectedAddress ? (selectedAddress.province + selectedAddress.city + selectedAddress.district + selectedAddress.detail) : '请选择收货地址'}}
      </view>
    </view>
    <view class="address-arrow">›</view>
  </view>

  <!-- 商品清单 -->
  <view class="goods-section">
    <view class="section-title">商品清单</view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{checkoutItems}}" wx:key="id">
        <image class="goods-image" src="{{item.image || 'https://picsum.photos/seed/book/200/280'}}"></image>
        <view class="goods-info">
          <view class="goods-title">{{item.title}}</view>
          <view class="goods-author">{{item.author}}</view>
          <view class="goods-meta">
            <text class="goods-price">¥{{item.price}}</text>
            <text class="goods-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="price-section">
    <view class="price-item">
      <text class="price-label">商品总价</text>
      <text class="price-value">¥{{totalPrice}}</text>
    </view>
    <view class="price-item">
      <text class="price-label">运费</text>
      <text class="price-value">免运费</text>
    </view>
    <view class="price-item total">
      <text class="total-label">实付款</text>
      <text class="total-value">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-list">
      <view class="payment-item" bindtap="selectPayment" data-payment="wechat">
        <view class="payment-info">
          <text class="payment-icon">💳</text>
          <text class="payment-name">微信支付</text>
        </view>
        <view class="payment-check {{selectedPayment === 'wechat' ? 'active' : ''}}">
          <text wx:if="{{selectedPayment === 'wechat'}}" class="check-icon">✓</text>
        </view>
      </view>
      <view class="payment-item" bindtap="selectPayment" data-payment="alipay">
        <view class="payment-info">
          <text class="payment-icon">💳</text>
          <text class="payment-name">支付宝</text>
        </view>
        <view class="payment-check {{selectedPayment === 'alipay' ? 'active' : ''}}">
          <text wx:if="{{selectedPayment === 'alipay'}}" class="check-icon">✓</text>
        </view>
      </view>
      <view class="payment-item" bindtap="selectPayment" data-payment="card">
        <view class="payment-info">
          <text class="payment-icon">💳</text>
          <text class="payment-name">银行卡</text>
        </view>
        <view class="payment-check {{selectedPayment === 'card' ? 'active' : ''}}">
          <text wx:if="{{selectedPayment === 'card'}}" class="check-icon">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text class="total-text">合计：</text>
      <text class="total-amount">¥{{totalPrice}}</text>
      <view class="actions">
        <button class="cancel-btn" bindtap="cancelOrder" loading="{{loading}}">取消</button>
        <button class="submit-btn" bindtap="submitOrder" loading="{{loading}}">提交订单</button>
      </view>
    </view>
  </view>

  <!-- 支付密码弹窗 -->
  <view class="password-modal {{showPasswordModal ? 'show' : ''}}">
    <view class="modal-mask" bindtap="closePasswordModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">请输入支付密码</text>
        <view class="modal-close" bindtap="closePasswordModal">×</view>
      </view>
      <view class="modal-body">
        <view class="password-amount">
          <text class="amount-label">支付金额</text>
          <text class="amount-value">¥{{totalPrice}}</text>
        </view>
        <view class="password-input-box">
          <view class="password-dots">
            <view class="password-dot {{password.length >= 1 ? 'filled' : ''}}"></view>
            <view class="password-dot {{password.length >= 2 ? 'filled' : ''}}"></view>
            <view class="password-dot {{password.length >= 3 ? 'filled' : ''}}"></view>
            <view class="password-dot {{password.length >= 4 ? 'filled' : ''}}"></view>
            <view class="password-dot {{password.length >= 5 ? 'filled' : ''}}"></view>
            <view class="password-dot {{password.length >= 6 ? 'filled' : ''}}"></view>
          </view>
          <input 
            type="number" 
            class="password-input" 
            maxlength="6" 
            focus="{{showPasswordModal}}"
            bindinput="onPasswordInput"
            value="{{password}}"
          />
        </view>
        <view class="password-error" wx:if="{{passwordError}}">{{passwordError}}</view>
      </view>
      <view class="modal-footer">
        <view class="forget-password" bindtap="onForgetPassword">忘记密码?</view>
      </view>
    </view>
  </view>
</view>