/* pages/checkout/checkout.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

.header {
  background-color: #fff;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header .title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  display: block;
}

/* 地址部分 */
.address-section {
  background-color: #fff;
  margin: 20rpx 0;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-header .name {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.address-header .phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.address-arrow {
  font-size: 40rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 商品清单部分 */
.goods-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-author {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 30rpx;
  color: #ff4757;
  font-weight: bold;
}

.goods-quantity {
  font-size: 28rpx;
  color: #999;
}

/* 价格信息部分 */
.price-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.price-item.total {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.total-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #eee;
  height: 100rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  display: flex;
  align-items: center;
}

.total-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 8rpx;
}

.total-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4757;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.cancel-btn {
  width: 40rpx;
  height: 75rpx;
  line-height: 75rpx;
  background-color: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 25rpx;
  font-size: 30rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

.submit-btn {
  width: 45rpx;
  height: 75rpx;
  line-height: 75rpx;
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 25rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

/* 支付方式部分 */
.payment-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
}

.payment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.payment-icon {
  font-size: 40rpx;
}

.payment-name {
  font-size: 30rpx;
  color: #333;
}

.payment-check {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.payment-check.active {
  background-color: #ff4757;
  border-color: #ff4757;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 支付密码弹窗 */
.password-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.password-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background-color: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  z-index: 1001;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  position: relative;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.password-amount {
  text-align: center;
  margin-bottom: 40rpx;
}

.amount-label {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.amount-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.password-input-box {
  position: relative;
  width: 100%;
}

.password-dots {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.password-dot {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  transition: all 0.3s;
}

.password-dot.filled {
  background-color: #333;
  border-color: #333;
}

.password-dot.filled::after {
  content: '';
  width: 16rpx;
  height: 16rpx;
  background-color: #fff;
  border-radius: 50%;
}

.password-input {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 80rpx;
  opacity: 0;
  z-index: 10;
}

.password-error {
  text-align: center;
  color: #ff4757;
  font-size: 28rpx;
  margin-top: 20rpx;
  min-height: 40rpx;
}

.modal-footer {
  padding: 20rpx 30rpx 40rpx;
  text-align: center;
}

.forget-password {
  font-size: 28rpx;
  color: #576b95;
  cursor: pointer;
}

/* 优惠券样式 */
.coupon-value {
  display: flex;
  align-items: center;
}

.coupon-discount {
  color: #ff4757;
  font-size: 28rpx;
}

.coupon-placeholder {
  color: #999;
  font-size: 28rpx;
}

.picker-arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 优惠券弹窗 */
.coupon-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.coupon-modal.show {
  opacity: 1;
  visibility: visible;
}

.coupon-modal-content {
  position: relative;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 70vh;
  z-index: 1001;
  display: flex;
  flex-direction: column;
}

.coupon-modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.no-coupon {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coupon-item {
  display: flex;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
  border: 2rpx solid #ffe0e0;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.coupon-item.selected {
  border-color: #ff4757;
  background: linear-gradient(135deg, #fff0f0 0%, #fff 100%);
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #ff4757 0%, #ff6b7a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  color: #fff;
}

.coupon-amount {
  font-size: 48rpx;
  font-weight: bold;
}

.coupon-condition {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.coupon-expire {
  font-size: 22rpx;
  color: #999;
}

.coupon-check {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4757;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.coupon-modal-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
}

.confirm-btn {
  width: 100%;
  height: 80rpx;
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}