/* pages/checkout/checkout.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

.header {
  background-color: #fff;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header .title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  display: block;
}

/* 地址部分 */
.address-section {
  background-color: #fff;
  margin: 20rpx 0;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-header .name {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.address-header .phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.address-arrow {
  font-size: 40rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 商品清单部分 */
.goods-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-author {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 30rpx;
  color: #ff4757;
  font-weight: bold;
}

.goods-quantity {
  font-size: 28rpx;
  color: #999;
}

/* 价格信息部分 */
.price-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.price-item.total {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.total-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #eee;
  height: 100rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  display: flex;
  align-items: center;
}

.total-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 8rpx;
}

.total-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4757;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.cancel-btn {
  width: 40rpx;
  height: 75rpx;
  line-height: 75rpx;
  background-color: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 25rpx;
  font-size: 30rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

.submit-btn {
  width: 45rpx;
  height: 75rpx;
  line-height: 75rpx;
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 25rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}