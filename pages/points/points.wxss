/* pages/points/points.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-left {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.header-right {
  width: 60rpx;
}

.points-balance {
  background: linear-gradient(135deg, #ff9800 0%, #ff6b00 100%);
  padding: 50rpx 30rpx;
  margin-top: 100rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.points-balance::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transform: translate(50%, -50%);
}

.balance-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.points-label {
  font-size: 30rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 10rpx;
}

.points-value {
  font-size: 60rpx;
  font-weight: bold;
  display: block;
}

.exchange-btn {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  padding: 15rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  line-height: 1.4;
}

.tab-container {
  display: flex;
  background-color: #fff;
  margin-top: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  padding: 26rpx 0;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #ff9800;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #ff9800;
  border-radius: 2rpx;
}

.content-container {
  background-color: #fff;
  min-height: 500rpx;
}

.loading-container {
  padding: 80rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}

.history-list {
  padding: 0 30rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.history-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 50%;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
}

.history-desc {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.history-time {
  font-size: 26rpx;
  color: #999;
}

.history-right {
  font-size: 34rpx;
  font-weight: 500;
}

.points-in {
  color: #07c160;
}

.points-out {
  color: #ff6b00;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

.rules-container {
  padding: 30rpx;
}

.rule-section {
  margin-bottom: 40rpx;
}

.rule-section:last-child {
  margin-bottom: 0;
}

.rule-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.rule-item {
  display: flex;
  margin-bottom: 25rpx;
  padding-left: 10rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-icon {
  width: 60rpx;
  font-size: 36rpx;
  text-align: center;
  margin-right: 20rpx;
}

.rule-content {
  flex: 1;
}

.rule-text {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.rule-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 38rpx;
}