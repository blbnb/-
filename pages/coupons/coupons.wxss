/* pages/coupons/coupons.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-left {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.header-right {
  width: 60rpx;
}

.tab-container {
  display: flex;
  background-color: #fff;
  margin-top: 100rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  padding: 26rpx 0;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #07c160;
  border-radius: 2rpx;
}

.coupons-container {
  padding: 20rpx;
}

.loading-container {
  padding: 80rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}

.coupon-item {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.coupon-item .disabled {
  opacity: 0.6;
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #07c160 0%, #06c25b 100%);
  color: #fff;
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.coupon-left.disabled {
  background: linear-gradient(135deg, #999 0%, #888 100%);
}

.coupon-value {
  font-size: 36rpx;
  font-weight: bold;
}

.value-sign {
  font-size: 28rpx;
  font-weight: normal;
}

.value-amount {
  font-size: 48rpx;
}

.coupon-condition {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

.coupon-right {
  flex: 1;
  padding: 20rpx 30rpx;
  position: relative;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.coupon-description {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
  line-height: 40rpx;
}

.coupon-expire {
  font-size: 24rpx;
  color: #999;
}

.status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.status-tag.used {
  background-color: #e0e0e0;
  color: #999;
}

.status-tag.expired {
  background-color: #ffebee;
  color: #f44336;
}

.coupon-sawtooth {
  position: absolute;
  top: 0;
  left: 200rpx;
  width: 20rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0;
  margin: 0;
  z-index: 3;
}

.tooth {
  width: 0;
  height: 10rpx;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 10rpx solid #f5f5f5;
  margin-left: -10rpx;
}

.tooth:nth-child(odd) {
  border-bottom: none;
  border-top: 10rpx solid #f5f5f5;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}