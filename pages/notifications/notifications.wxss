/* pages/notifications/notifications.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 页面头部样式 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

/* 空占位符样式 */
.empty {
  width: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  padding: 0 20rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
}

.clear-text {
  font-size: 28rpx;
  color: #666;
}

/* 标签切换样式 */
.tabs {
  display: flex;
  background-color: #fff;
  margin-top: 100rpx;
  padding: 20rpx 0;
  position: fixed;
  top: 100rpx;
  left: 0;
  right: 0;
  z-index: 99;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  position: relative;
}

.tab-item text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active text {
  color: #ff6600;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 4rpx;
  background-color: #ff6600;
  border-radius: 2rpx;
}

/* 通知列表样式 */
.notification-list {
  padding-top: 200rpx;
  padding-bottom: 30rpx;
}

.notification-item {
  display: flex;
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx 30rpx;
  position: relative;
  transition: background-color 0.3s;
}

.notification-item:active {
  background-color: #f8f8f8;
}

.notification-item.read {
  background-color: #fafafa;
}

/* 未读标记 */
.unread-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ff6600;
  border-radius: 50%;
  margin-right: 15rpx;
  margin-top: 18rpx;
  flex-shrink: 0;
}

/* 通知内容 */
.notification-content {
  flex: 1;
  padding-right: 40rpx;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.notification-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-time {
  font-size: 24rpx;
  color: #999;
}

.notification-body {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 10rpx;
}

/* 通知类型标签 */
.notification-type {
  margin-top: 10rpx;
}

.type-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.type-tag.system {
  background-color: #e6f7ff;
  color: #1890ff;
}

.type-tag.order {
  background-color: #fff7e6;
  color: #fa8c16;
}

.type-tag.promotion {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.notification-item:hover .delete-btn {
  opacity: 1;
}

.delete-icon {
  font-size: 36rpx;
  color: #999;
  font-weight: 300;
}

.delete-btn:active .delete-icon {
  color: #ff6600;
}

/* 加载中状态 */
.loading {
  padding: 60rpx 0;
  text-align: center;
}

.loading text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 响应式调整 */
@media screen and (min-width: 768px) {
  .notification-list {
    max-width: 700rpx;
    margin: 0 auto;
  }
  
  .notification-item .delete-btn {
    opacity: 1;
  }
}