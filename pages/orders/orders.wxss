/* pages/orders/orders.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 页面头部样式 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}



.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.empty {
  width: 60rpx;
}

/* 订单状态筛选器样式 */
.status-filter {
  display: flex;
  background-color: #fff;
  margin-top: 0;
  padding: 20rpx 0;
  position: fixed;
  top: 100rpx;
  left: 0;
  right: 0;
  z-index: 99;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.status-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  position: relative;
}

.status-item text {
  font-size: 28rpx;
  color: #666;
}

.status-item.active text {
  color: #ff6600;
  font-weight: 600;
}

.status-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 4rpx;
  background-color: #ff6600;
  border-radius: 2rpx;
}

/* 订单列表样式 */
.order-list {
  padding: 20rpx;
  padding-top: 220rpx; /* 为固定头部和筛选器留出空间 */
  padding-bottom: 30rpx;
}

.order-item {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
}

/* 订单头部信息 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  font-size: 28rpx;
  color: #ff6600;
  font-weight: 600;
}

.countdown {
  color: #ff4757;
  font-weight: 600;
  font-size: 26rpx;
}

/* 订单收货地址 */
.order-address {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.address-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-info .name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-right: 20rpx;
}

.address-info .phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

/* 订单商品列表 */
.order-items {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-item {
  display: flex;
  margin-bottom: 20rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 140rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-price-quantity {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 30rpx;
  color: #ff6600;
  font-weight: 600;
}

.product-quantity {
  font-size: 26rpx;
  color: #999;
}

/* 订单底部信息 */
.order-footer {
  padding-top: 20rpx;
}

.order-total {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-total text {
  font-size: 26rpx;
  color: #666;
}

.total-price {
  font-size: 28rpx;
  color: #ff6600;
  font-weight: 600;
  margin-left: 20rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 15rpx;
}

/* 按钮样式 */
.btn-primary {
  background-color: #ff6600;
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.btn-secondary::after {
  border: none;
}

/* 加载中状态 */
.loading {
  padding: 60rpx 0;
  text-align: center;
}

.loading text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  display: block;
}

/* 响应式调整 */
@media screen and (min-width: 768px) {
  .order-list {
    max-width: 700rpx;
    margin: 0 auto;
  }
}