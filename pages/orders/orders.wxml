<!-- pages/orders/orders.wxml -->
<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="empty"></view>
    <view class="title">我的订单</view>
    <view class="empty"></view>
  </view>

  <!-- 订单状态筛选器 -->
  <view class="status-filter">
    <view wx:for="{{statusOptions}}" wx:key="key"
          class="status-item {{currentStatus === item.key ? 'active' : ''}}"
          data-status="{{item.key}}"
          bindtap="switchStatus">
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:if="{{!loading && !emptyState}}">
      <view wx:for="{{orders}}" wx:key="id" class="order-item">
        <!-- 订单头部信息 -->
        <view class="order-header">
          <view class="order-no">订单号: {{item.orderNo}}</view>
          <view class="order-status">
            {{getStatusText(item.status)}}
            <text wx:if="{{item.status === 'pending' && item.countdown > 0}}" class="countdown"> ({{item.countdown}}s)</text>
          </view>
        </view>

        <!-- 订单收货地址 -->
        <view class="order-address">
          <view class="address-info">
            <text class="name">{{item.address.name}} </text>
            <text class="phone">{{item.address.phone}}</text>
          </view>
          <view class="address-detail">{{item.address.address}}</view>
        </view>

        <!-- 订单商品列表 -->
        <view class="order-items">
          <view wx:for="{{item.items}}" wx:for-item="product" wx:key="id" class="product-item">
            <image class="product-image" src="{{product.image || '/Default.jpg'}}" mode="aspectFit"></image>
            <view class="product-info">
              <text class="product-title">{{product.title}}</text>
              <view class="product-price-quantity">
                <text class="product-price">¥{{product.price}}</text>
                <text class="product-quantity">x{{product.quantity}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 订单底部信息 -->
        <view class="order-footer">
          <view class="order-total">
            <text>共 {{item.totalItems || 0}} 件商品</text>
            <text class="total-price">合计: ¥{{item.totalAmount}}</text>
          </view>
          <view class="order-actions">
            <!-- 根据订单状态显示不同的操作按钮 -->
            <block wx:if="{{item.status === 'pending'}}">
              <button class="btn-secondary" size="mini" data-id="{{item.id}}" bindtap="cancelOrder">取消订单</button>
              <button class="btn-primary" size="mini" data-id="{{item.id}}" bindtap="payOrder">立即支付</button>
            </block>
            <block wx:elif="{{item.status === 'shipped'}}">
              <button class="btn-primary" size="mini" data-id="{{item.id}}" bindtap="confirmReceipt">确认收货</button>
            </block>
            <block wx:elif="{{item.status === 'received'}}">
              <button class="btn-primary" size="mini" data-id="{{item.id}}" bindtap="reviewOrder">去评价</button>
            </block>
            <block wx:else>
              <button class="btn-secondary" size="mini" data-id="{{item.id}}" bindtap="viewOrderDetail">查看详情</button>
            </block>
          </view>
        </view>
      </view>
    </block>

    <!-- 加载中状态 -->
    <block wx:if="{{loading}}">
      <view class="loading">
        <text>加载中...</text>
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:if="{{!loading && emptyState}}">
      <view class="empty-state">
        <image src="/assets/images/empty-notification.svg" mode="aspectFit"></image>
        <text class="empty-text">暂无订单</text>
        <button class="btn-primary" bindtap="goBack">去购物</button>
      </view>
    </block>
  </view>
</view>