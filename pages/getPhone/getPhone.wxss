/* pages/getPhone/getPhone.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #ffffff;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  position: relative;
}

/* 加载遮罩层 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.7);
  padding: 30rpx 60rpx;
  border-radius: 16rpx;
  color: #ffffff;
}

.loading-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  border-top-color: #ffffff;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #ffffff;
}

/* 头部样式 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  padding-top: 120rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #000000;
}

.subtitle {
  font-size: 28rpx;
  color: #666666;
}

/* 内容区域 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 100%;
  padding: 0 20rpx;
}

/* 手机号显示项 */
.phone-item {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.phone-number {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.phone-label {
  font-size: 26rpx;
  color: #999999;
  display: block;
}

/* 不允许按钮 */
.deny-button {
  width: 100%;
  font-size: 32rpx;
  border-radius: 12rpx;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #f5f5f5;
  color: #333333;
  border: none;
  margin-bottom: 40rpx;
}

/* 使用其它号码选项 */
.other-option {
  text-align: center;
}

.other-phone-text {
  font-size: 30rpx;
  color: #1989fa;
}

/* 右上角信息图标 */
.info-icon {
  position: absolute;
  top: 60rpx;
  right: 60rpx;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.info-icon text {
  font-size: 26rpx;
  color: #666666;
  font-style: italic;
}