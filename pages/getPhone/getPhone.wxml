<!-- pages/getPhone/getPhone.wxml -->
<view class="container">
  <!-- 加载遮罩层 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">处理中...</text>
    </view>
  </view>
  
  <view class="header">
    <text class="title">申请获取并验证你的手机号</text>
    <text class="subtitle">登录或注册</text>
  </view>
  
  <view class="content">
    <!-- 微信绑定号码显示 -->
    <view class="phone-item" bindtap="handlePhoneSelect">
      <text class="phone-number">{{maskedPhone || '191****1234'}}</text>
      <text class="phone-label">微信绑定号码</text>
    </view>
    
    <!-- 不允许按钮 -->
    <button 
        id="phoneButton"
        open-type="getPhoneNumber" 
        bindgetphonenumber="getPhoneNumber" 
        class="deny-button" 
        type="default"
        disabled="{{loading}}"
      >
        不允许
      </button>
    
    <!-- 使用其它号码选项 -->
    <view class="other-option" bindtap="useOtherPhone">
      <text class="other-phone-text">使用其它号码</text>
    </view>
  </view>
  
  <!-- 右上角信息图标 -->
  <view class="info-icon" bindtap="showPrivacyInfo">
    <text>i</text>
  </view>
</view>