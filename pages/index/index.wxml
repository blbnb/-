<!-- 首页 -->
<view class="page">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="logo">
      <text class="logo-text">校园书屋</text>
    </view>
    <view class="search-input-wrapper" bindtap="goToSearch">
      <view class="search-input">
        <text class="icon-search">🔍</text>
        <input type="text" placeholder="搜索图书名称、作者或ISBN..." placeholder-class="placeholder" disabled />
      </view>
    </view>
    <view class="user-actions">
      <view class="cart-icon" bindtap="goToCart">
        <text>🛒</text>
        <view class="cart-count" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
    </view>
  </view>

  <!-- 轮播图 -->
  <view class="carousel">
    <swiper indicator-dots="true" autoplay="true" interval="5000" duration="1000">
      <swiper-item>
        <view class="carousel-item">
          <image src="https://picsum.photos/seed/carousel1/750/300" mode="aspectFill"></image>
          <view class="carousel-text">
            <text class="carousel-title">新学期图书特惠</text>
            <text class="carousel-subtitle">全场二手教材低至5折起</text>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="carousel-item">
          <image src="https://picsum.photos/seed/carousel2/750/300" mode="aspectFill"></image>
          <view class="carousel-text">
            <text class="carousel-title">畅销图书推荐</text>
            <text class="carousel-subtitle">精选热门课外读物</text>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="carousel-item">
          <image src="https://picsum.photos/seed/carousel3/750/300" mode="aspectFill"></image>
          <view class="carousel-text">
            <text class="carousel-title">图书回收计划</text>
            <text class="carousel-subtitle">让闲置图书流动起来</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 学院分类 -->
  <view class="category-section">
    <view class="section-title">
      <text class="title-icon">📚</text>
      <text class="title-text">学院分类</text>
    </view>
    <view class="category-list">
      <view class="category-item" wx:for="{{categories}}" wx:key="index" bindtap="goToCategory" data-category="{{item.name}}">
        <view class="category-icon" style="background-color: {{item.bgColor}}">
          <text class="icon">{{item.icon}}</text>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 推荐图书 -->
  <view class="recommend-section">
    <view class="section-title">
      <text class="title-text">推荐图书</text>
      <text class="more-text">更多 ></text>
    </view>
    <view class="book-list">
      <view class="book-item" wx:for="{{recommendBooks}}" wx:key="index" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="book-img-container">
          <image src="{{item.image || '/Default.jpg'}}" mode="aspectFill"></image>
          <text class="book-tag" wx:if="{{item.tags && item.tags.length > 0}}">{{item.tags[0]}}</text>
        </view>
        <view class="book-info">
          <text class="book-title">{{item.title}}</text>
          <text class="book-author" wx:if="{{item.author}}">{{item.author}}</text>
          <view class="price-container">
            <text class="book-price">¥{{item.price}}</text>
            <text class="original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
            <text class="discount-tag" wx:if="{{item.originalPrice}}">{{Math.round(item.price / item.originalPrice * 10)}}折</text>
          </view>
        </view>
      </view>
    </view>
  </view>


</view>