/* 首页样式 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.logo {
  flex-shrink: 0;
}

.logo-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #4F46E5;
}

.search-input-wrapper {
  flex: 1;
  margin: 0 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 60rpx;
  padding: 12rpx 20rpx;
}

.icon-search {
  font-size: 28rpx;
  color: #999;
  margin-right: 10rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  background: transparent;
}

.placeholder {
  color: #999;
}

.user-actions {
  display: flex;
  align-items: center;
}

.cart-icon {
  position: relative;
  font-size: 36rpx;
  margin-left: 30rpx;
}

.cart-count {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #F59E0B;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
}

/* 轮播图 */
.carousel {
  height: 300rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.carousel-item {
  position: relative;
  height: 300rpx;
}

.carousel-item image {
  width: 100%;
  height: 100%;
}

.carousel-text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 30rpx;
}

.carousel-title {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.carousel-subtitle {
  display: block;
  color: #fff;
  font-size: 28rpx;
}

/* 分类区域 */
.category-section {
  background-color: #fff;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.more-text {
  font-size: 28rpx;
  color: #999;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.category-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
}

.category-icon .icon {
  font-size: 48rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333;
}

/* 图书区域 */
.recommend-section,
.discount-section {
  background-color: #fff;
  padding: 30rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  position: relative;
  padding-left: 12rpx;
}

.title-text::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background-color: #4F46E5;
  border-radius: 3rpx;
}

.more-text {
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  transition: color 0.3s ease;
}

.more-text:active {
  color: #4F46E5;
}

.book-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin: 0 -12rpx;
}

.book-item {
  width: calc(50% - 24rpx);
  margin: 0 12rpx 36rpx 12rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: all 0.3s ease;
  transform: translateY(0);
  position: relative;
}

.book-item:active {
  transform: translateY(4rpx);
  box-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.04);
}

.book-item::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(79, 70, 229, 0.05) 0%, rgba(245, 158, 11, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.book-item:active::after {
  opacity: 1;
}

.book-item .book-img-container {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  background-color: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.book-item image {
  width: 100%;
  height: 100%;
  display: block;
  transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  object-fit: cover;
}

.book-item:active image {
  transform: scale(1.05);
}

.book-item .book-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 22rpx;
  color: #fff;
  background-color: #4F46E5;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.3);
}

.book-info {
  padding: 24rpx 20rpx;
}

.book-title {
  font-size: 32rpx;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
  line-height: 1.45;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.book-author {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 16rpx;
  font-weight: 400;
}

.price-container {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.book-price {
  font-size: 38rpx;
  color: #EF4444;
  font-weight: bold;
  display: inline-block;
  position: relative;
  margin-right: 12rpx;
}

.book-price::first-letter {
  font-size: 30rpx;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-right: 12rpx;
  position: relative;
}

.discount-tag {
  font-size: 20rpx;
  color: #fff;
  background-color: #F59E0B;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

/* 加载动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.book-item {
  animation: fadeInUp 0.5s ease-out;
}

.book-item:nth-child(1) { animation-delay: 0.1s; }
.book-item:nth-child(2) { animation-delay: 0.2s; }
.book-item:nth-child(3) { animation-delay: 0.3s; }
.book-item:nth-child(4) { animation-delay: 0.4s; }
.book-item:nth-child(5) { animation-delay: 0.5s; }
.book-item:nth-child(6) { animation-delay: 0.6s; }