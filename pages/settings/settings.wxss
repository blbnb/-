/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 头部样式 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid #eee;
}

.header-left, .header-right {
  width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: #333;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 500;
  color: #333;
}

.empty {
  height: 44px;
}

/* 设置项样式 */
.settings-container {
  padding: 10px 0;
}

.settings-section {
  margin-bottom: 10px;
  background-color: #fff;
  margin-top: 120rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.setting-icon {
  font-size: 20px;
  margin-right: 12px;
  width: 20px;
  text-align: center;
}

.setting-text {
  font-size: 16px;
  color: #333;
  margin-right: 8px;
}

.setting-desc {
  font-size: 13px;
  color: #999;
  margin-top: 2px;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-arrow {
  font-size: 14px;
  color: #999;
  margin-left: 8px;
}

.setting-value {
  font-size: 15px;
  color: #999;
}

/* 清除缓存按钮 */
.clear-cache-btn {
  margin: 20px 16px;
  padding: 12px 0;
  background-color: #ff6600;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-size: 16px;
  text-align: center;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 20px 0;
  font-size: 13px;
  color: #999;
}

/* 通知设置和隐私设置页面特定样式 */
.section-title {
  font-size: 14px;
  color: #999;
  padding: 12px 16px 8px;
  background-color: #f5f5f5;
}

/* 提示信息 */
.tips {
  padding: 16px;
}

.tips-text {
  font-size: 13px;
  color: #999;
  line-height: 1.5;
}

/* 关于我们页面样式 */
.about-container {
  padding: 20px 16px;
}

.app-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
}

.app-logo {
  width: 80px;
  height: 80px;
  border-radius: 16px;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.logo-icon {
  font-size: 40px;
}

.app-name {
  font-size: 18px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.app-version {
  font-size: 14px;
  color: #999;
}

.company-info {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 20px;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 15px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 15px;
  color: #999;
  width: 80px;
}

.info-value {
  font-size: 15px;
  color: #333;
  flex: 1;
}

.info-link {
  display: flex;
  align-items: center;
  flex: 1;
}

.info-arrow {
  font-size: 14px;
  color: #999;
  margin-left: 4px;
}

.action-section {
  padding: 0 16px;
  margin-bottom: 20px;
}

.action-btn {
  background-color: #ff6600;
  color: #fff;
  font-size: 16px;
  border-radius: 4px;
  border: none;
  padding: 12px 0;
  width: 100%;
}

.copyright {
  text-align: center;
  padding: 20px 0;
}

.copyright-text {
  font-size: 13px;
  color: #999;
}

/* 协议和政策页面样式 */
.content {
  flex: 1;
  height: calc(100vh - 44px);
}

.agreement-container,
.policy-container {
  padding: 16px;
}

.agreement-header,
.policy-header {
  text-align: center;
  margin-bottom: 20px;
}

.agreement-title,
.policy-title {
  font-size: 18px;
  font-weight: 500;
  color: #333;
  margin-bottom: 8px;
}

.agreement-subtitle,
.policy-subtitle {
  font-size: 14px;
  color: #999;
}

.agreement-content,
.policy-content {
  margin-bottom: 20px;
}

.section-item {
  margin-bottom: 20px;
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  margin-bottom: 8px;
  background-color: transparent;
  padding: 0;
}

.section-content {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

.footer {
  text-align: center;
  padding: 20px 0;
  border-top: 1px solid #eee;
}

.footer-text {
  font-size: 13px;
  color: #999;
}

/* 账号与安全页面样式 */
.security-container {
  padding: 10px 0;
}

.security-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px 16px;
  background-color: #fff;
  margin-bottom: 10px;
  border-radius: 8px;
}

.security-info {
  display: flex;
  align-items: center;
}

.security-icon {
  font-size: 20px;
  margin-right: 12px;
  width: 20px;
  text-align: center;
}

.security-text {
  font-size: 16px;
  color: #333;
}

.security-value {
  font-size: 14px;
  color: #999;
  margin-right: 8px;
}

.security-hint {
  font-size: 13px;
  color: #999;
  padding: 16px;
  text-align: center;
  line-height: 1.5;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .setting-item,
  .info-item {
    padding: 18px 20px;
  }
  
  .setting-text,
  .info-value {
    font-size: 17px;
  }
}