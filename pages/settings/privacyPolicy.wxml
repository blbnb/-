<!-- pages/settings/privacyPolicy.wxml -->
<view class="page">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-title">隐私政策</view>
    <view class="header-right empty"></view>
  </view>

  <scroll-view class="content" scroll-y="true">
    <view class="policy-container">
      <view class="policy-header">
        <text class="policy-title">隐私保护政策</text>
        <text class="policy-subtitle">（我们重视您的隐私安全）</text>
      </view>

      <view class="policy-content">
        <block wx:for="{{policyContent}}" wx:key="index">
          <view class="section-item">
            <text class="section-title">{{item.title}}</text>
            <text class="section-content">{{item.content}}</text>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>

  <view class="footer">
    <text class="footer-text">© 2024 书香科技有限公司 版权所有</text>
  </view>
</view>