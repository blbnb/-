<!-- pages/settings/privacySettings.wxml -->
<view class="page">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-title">隐私设置</view>
    <view class="header-right empty"></view>
  </view>

  <view class="settings-section">
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📍</text>
        <text class="setting-text">允许获取位置信息</text>
        <text class="setting-desc">用于提供附近书店和配送服务</text>
      </view>
      <view class="setting-right">
        <switch checked="{{isLocationEnabled}}" bindchange="toggleLocation" color="#ff6600"></switch>
      </view>
    </view>
    </view>

  <view class="settings-section">
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📚</text>
        <text class="setting-text">个性化推荐</text>
        <text class="setting-desc">根据阅读偏好推荐相关书籍</text>
      </view>
      <view class="setting-right">
        <switch checked="{{isRecommendEnabled}}" bindchange="toggleRecommend" color="#ff6600"></switch>
      </view>
    </view>
    </view>

  <view class="settings-section">
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📊</text>
        <text class="setting-text">使用数据统计分析</text>
        <text class="setting-desc">帮助我们改进产品体验</text>
      </view>
      <view class="setting-right">
        <switch checked="{{isAnalyticsEnabled}}" bindchange="toggleAnalytics" color="#ff6600"></switch>
      </view>
    </view>
    </view>

  <view class="settings-section">
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">🔗</text>
        <text class="setting-text">允许分享内容
        </text>
        <text class="setting-desc">允许将书籍和活动分享给好友
        </text>
      </view>
      <view class="setting-right">
        <switch checked="{{isShareEnabled}}" bindchange="toggleShare" color="#ff6600"></switch>
      </view>
    </view>
  </view>

  <view class="tips">
    <text class="tips-text">💡 您可以随时修改这些设置来保护您的隐私安全</text>
  </view>
</view>