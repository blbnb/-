/* pages/favorites/favorites.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header .title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 20rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #ff6b6b;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #ff6b6b;
  color: #fff;
  font-size: 32rpx;
}

.favorite-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.favorite-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
}

.book-info {
  display: flex;
  margin-bottom: 20rpx;
}

.book-image {
  width: 200rpx;
  height: 280rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
}

.book-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.book-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-author {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.book-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.book-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.book-publisher {
  font-size: 26rpx;
  color: #999;
}

.book-stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 12rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
}

.favorite-time {
  font-size: 24rpx;
  color: #999;
}

.action {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.remove-btn {
  color: #ff6b6b;
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid #ff6b6b;
  border-radius: 16rpx;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}