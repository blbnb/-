<!-- pages/favorites/favorites.wxml -->
<view class="page">
  <view class="header">
    <text class="title">我的收藏</text>
  </view>

  <view class="content">
    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading && favorites.length === 0}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:elif="{{!loading && favorites.length === 0}}">
      <text class="empty-icon">❤️</text>
      <text class="empty-text">您还没有收藏任何图书</text>
      <button class="empty-btn" bindtap="goToHome">去逛逛</button>
    </view>

    <!-- 收藏列表 -->
    <view class="favorite-list" wx:else>
      <view class="favorite-item" wx:for="{{favorites}}" wx:key="id">
        <view class="book-info" bindtap="goToBookDetail" data-id="{{item.book.id}}">
          <image class="book-image" src="{{item.book.image || '/Default.jpg'}}" mode="aspectFill"></image>
          <view class="book-details">
            <view class="book-title">{{item.book.title}}</view>
            <view class="book-author">{{item.book.author}}</view>
            <view class="book-meta">
              <text class="book-price">¥{{item.book.price}}</text>
              <text class="book-publisher">{{item.book.publisher}}</text>
            </view>
            <view class="book-stats">
              <text class="stat-item">📅 {{item.book.publishDate}}</text>
              <text class="stat-item">👁️ {{item.book.viewCount}}次浏览</text>
            </view>
            <view class="favorite-time">
              <text>收藏于 {{item.createTime}}</text>
            </view>
          </view>
        </view>
        <view class="action" bindtap="removeFromFavorites" data-fav-id="{{item.id}}" data-index="{{index}}">
          <text class="remove-btn">取消收藏</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore && !loading && favorites.length > 0}}">
      <text>上拉加载更多</text>
    </view>
  </view>
</view>