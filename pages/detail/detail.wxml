<!-- pages/detail/detail.wxml -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 图书详情 -->
  <view wx:elif="{{bookDetail}}">
    <!-- 头部信息区域 -->
    <view class="header-section">
      <!-- 图书图片 -->
      <view class="book-image">
        <image src="{{bookDetail.image || 'https://picsum.photos/seed/book/400/500'}}" mode="aspectFill"></image>
      </view>
      
      <!-- 图书基本信息 -->
      <view class="book-basic-info">
        <view>
          <view class="book-title">{{bookDetail.title || '暂无标题'}}</view>
          <view class="book-author">{{bookDetail.author || '未知作者'}}</view>
          
          <!-- 价格区域 -->
          <view class="price-container">
            <view class="book-price">¥{{bookDetail.price || 0}}</view>
            <view class="original-price" wx:if="{{bookDetail.originalPrice && bookDetail.originalPrice > bookDetail.price}}">
              ¥{{bookDetail.originalPrice}}
            </view>
            <view class="discount-tag" wx:if="{{bookDetail.originalPrice && bookDetail.originalPrice > bookDetail.price}}">
              {{Math.floor((bookDetail.price / bookDetail.originalPrice) * 10)}}折
            </view>
          </view>
        </view>
        
        <!-- 统计信息 -->
        <view class="stats-container">
          <view class="stat-item">
            <text class="stat-icon">👁️</text>
            <text>{{bookDetail.viewCount || 0}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-icon">⭐</text>
            <text>{{bookDetail.favoriteCount || 0}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-icon">📦</text>
            <text>{{bookDetail.sales || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 内容信息区域 -->
    <view class="content-section">
      <!-- 图书元信息 -->
      <view class="section-title">基本信息</view>
      <view class="book-meta">
        <view class="meta-item">
          <text class="meta-label">出版社：</text>
          <text>{{bookDetail.publisher || '未知'}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-label">出版日期：</text>
          <text>{{bookDetail.publishDate || '未知'}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-label">成色：</text>
          <text>{{bookDetail.condition || '未知'}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-label">分类：</text>
          <text>{{bookDetail.category || '未知'}}</text>
        </view>
      </view>
      
      <!-- 图书描述 -->
      <view class="section-title">内容简介</view>
      <view class="book-description">{{bookDetail.description || '暂无描述'}}</view>
      
      <!-- 卖家信息 -->
      <view class="seller-info">
        <view class="section-title">卖家信息</view>
        <view class="seller-item">
          <text class="meta-label">昵称：</text>
          <text>{{bookDetail.sellerName || '未知'}}</text>
        </view>
        <view class="seller-item">
          <text class="meta-label">联系方式：</text>
          <text>{{bookDetail.contactInfo || '私聊获取'}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view wx:else class="no-data">
    <text>暂无图书信息</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="quantity-control">
      <text class="btn-minus" bindtap="decreaseQuantity" wx:if="{{quantity > 1}}">-</text>
      <text class="quantity">{{quantity}}</text>
      <text class="btn-plus" bindtap="increaseQuantity">+</text>
    </view>
    <view class="action-buttons">
        <view class="btn favorite {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
          <text class="star-icon">{{isFavorited ? '★' : '☆'}}</text>
        </view>
        <view class="btn add-to-cart" bindtap="addToCart">加入购物车</view>
        <view class="btn buy-now" bindtap="buyBook">立即购买</view>
      </view>
  </view>
</view>