<!-- pages/myBooks/myBooks.wxml -->
<view class="page">
  <view class="header">
    <text class="title">我的图书</text>
  </view>

  <view class="content">
    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading && books.length === 0}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:elif="{{!loading && books.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-text">您还没有购买图书</text>
      <button class="empty-btn" bindtap="goToHome">去逛逛</button>
    </view>

    <!-- 图书列表 -->
    <view class="book-list" wx:else>
      <view class="book-item" wx:for="{{books}}" wx:key="id" bindtap="goToBookDetail" data-id="{{item.id}}">
        <image class="book-image" src="{{item.image || 'https://picsum.photos/seed/book/200/280'}}" mode="aspectFill"></image>
        <view class="book-info">
          <view class="book-title">{{item.title}}</view>
          <view class="book-author">{{item.author}}</view>
          <view class="book-meta">
            <text class="book-price">¥{{item.price}}</text>
            <text class="book-status" wx:if="{{item.status === 'available'}}">在售</text>
            <text class="book-status sold" wx:elif="{{item.status === 'sold'}}">已售出</text>
            <text class="book-status pending" wx:else>待审核</text>
          </view>
          <view class="book-stats">
            <text class="stat-item">📅 {{item.publishDate}}</text>
            <text class="stat-item">👁️ {{item.viewCount}}次浏览</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore && !loading && books.length > 0}}">
      <text>上拉加载更多</text>
    </view>
  </view>
</view>