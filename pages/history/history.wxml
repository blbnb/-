<!-- pages/history/history.wxml -->
<view class="page">
  <view class="header">
    <text class="title">浏览历史</text>
    <view class="header-right">
      <text class="clear-btn" wx:if="{{history.length > 0}}" bindtap="clearHistory">清空</text>
    </view>
  </view>

  <view class="content">
    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading && history.length === 0}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:elif="{{!loading && history.length === 0}}">
      <text class="empty-icon">🕐</text>
      <text class="empty-text">暂无浏览历史</text>
      <button class="empty-btn" bindtap="goToHome">去逛逛</button>
    </view>

    <!-- 历史记录列表 -->
    <view class="history-list" wx:else>
      <view class="history-item" wx:for="{{history}}" wx:key="id" bindtap="goToBookDetail" data-id="{{item.book.id}}">
        <image class="book-image" src="{{item.book.image || '/Default.jpg'}}" mode="aspectFill"></image>
        <view class="book-info">
          <view class="book-title">{{item.book.title}}</view>
          <view class="book-author">{{item.book.author}}</view>
          <view class="book-meta">
            <text class="book-price">¥{{item.book.price}}</text>
            <text class="view-time">{{item.viewTime}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore && !loading && history.length > 0}}">
      <text>上拉加载更多</text>
    </view>
  </view>
</view>