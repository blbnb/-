.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  cursor: pointer;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  margin-right: 10rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.empty {
  width: 120rpx;
}

.content {
  padding: 20rpx;
  padding-top: 120rpx;
}

.form-group {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.image-upload {
  width: 200rpx;
  height: 280rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 多图上传样式 */
.image-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  width: 100%;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 280rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  z-index: 10;
}

.cover-tag {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  background-color: rgba(79, 70, 229, 0.9);
  color: #fff;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  z-index: 10;
}

.upload-btn {
  width: 200rpx;
  height: 280rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 80rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.price-input-wrapper {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
}

.currency {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-right: 10rpx;
}

.price-input {
  flex: 1;
  height: 80rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.price-display {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  height: 80rpx;
  background-color: #f9f9f9;
}

.price-text {
  font-size: 32rpx;
  color: #ff4757;
  font-weight: 600;
  margin-right: 10rpx;
}

.discount-info {
  font-size: 24rpx;
  color: #666;
  margin-left: 10rpx;
}

.category-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  min-height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  cursor: pointer;
  position: relative;
  background-color: #fff;
  transition: background-color 0.2s;
  width: 100%;
  box-sizing: border-box;
  z-index: 10;
}

.category-selector:active {
  background-color: #f5f5f5;
}

.category-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  pointer-events: none;
}

.category-text.placeholder {
  color: #999;
}

.arrow {
  font-size: 40rpx;
  color: #999;
  pointer-events: none;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-cancel {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 45rpx;
  font-size: 32rpx;
}

.btn-cancel::after {
  border: none;
}

.btn-publish {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  background-color: #4F46E5;
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
}

.btn-publish::after {
  border: none;
}

.btn-publish.loading {
  background-color: #a5a5a5;
}

.btn-publish[disabled] {
  background-color: #a5a5a5;
}
